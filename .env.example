# Base URL of the public Canari instance the showcase reads from.
# Used both server-side (public read-only API) and client-side (public logos).
# Optional: defaults to https://canari-emse.fr when unset.
PUBLIC_CANARI_URL=https://canari-emse.fr

# MiGallery avatar proxy (server-side only, never exposed to the browser).
# The /api/users/:id/avatar route fetches member faces from MiGallery with this
# dedicated key. The avatar endpoint is `${GALLERY_API_URL}/users/:id/avatar`.
GALLERY_API_URL=https://gallery.mitv.fr/api
GALLERY_API_KEY=
# Origin header sent to MiGallery, if it enforces one. Optional.
PORTAL_URL=https://portail-etu.emse.fr
