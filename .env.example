# Local development reference. In production these values are NOT read from a
# hand-written server file: the deploy workflow (.github/workflows/deploy.yml)
# rewrites ~/portail-etu/.env from GitHub Secrets on every push to main, so the
# server keeps no manual state and a fresh machine deploys identically. Set each
# of the four keys below as a GitHub Actions Secret (repo Settings > Secrets and
# variables > Actions) using the exact names shown here.

# Base URL of the public Canari instance the showcase reads from.
# Used both server-side (public read-only API) and client-side (public logos).
# Optional: defaults to https://canari-emse.fr when unset/empty.
PUBLIC_CANARI_URL=https://canari-emse.fr

# MiGallery avatar proxy (server-side only, never exposed to the browser).
# The /api/users/:id/avatar route fetches member faces from MiGallery with this
# dedicated key. The avatar endpoint is `${GALLERY_API_URL}/users/:id/avatar`.
# Optional: defaults to https://gallery.mitv.fr/api when unset/empty.
GALLERY_API_URL=https://gallery.mitv.fr/api
# The only true secret. Rotate it on MiGallery, then update the GitHub Secret.
# When unset/empty the avatar proxy is disabled (no crash).
GALLERY_API_KEY=
# Origin header sent to MiGallery, if it enforces one. Optional.
PORTAL_URL=https://portail-etu.emse.fr
